# =====================================================================
# .env.example — copy to .env and fill in. NEVER commit .env to git.
# This file is a placeholder; the Architect will expand it via ADR-XXX
# in the first ArchSpec PR. Variables added/removed here MUST be
# justified in an ADR.
# =====================================================================

# --- Telegram (openclaw provides the channel; bot token is per deployment) ---
TELEGRAM_BOT_TOKEN=

# --- LLM routing (primary: OmniRoute; direct keys are fallback only) ---
OMNIROUTE_BASE_URL=
OMNIROUTE_API_KEY=

# Direct provider fallbacks (use only if OmniRoute is down)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FIREWORKS_API_KEY=

# --- Whisper (v0.1: OpenAI API; v0.2: local faster-whisper) ---
WHISPER_PROVIDER=openai            # openai | local
OPENAI_WHISPER_MODEL=whisper-1

# --- Storage ---
DATABASE_URL=sqlite:./data/app.db

# --- OpenFoodFacts (no key required for read; declared for clarity) ---
OPENFOODFACTS_USER_AGENT=openclown-assistant/0.1 (po@example.com)

# --- App ---
NODE_ENV=development
LOG_LEVEL=info
